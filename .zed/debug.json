[
  {
    "label": "Debug dash",
    "adapter": "CodeLLDB",
    "request": "launch",
    "program": "$ZED_WORKTREE_ROOT/build/dash",
    "cwd": "$ZED_WORKTREE_ROOT/build",
    "build": {
      "command": "sh",
      "args": [
        "-c",
        "./ez build --type debug && mkdir -p build/resources && cp -a resources/. build/resources/"
      ],
      "cwd": "$ZED_WORKTREE_ROOT"
    }
  }
]
