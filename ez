#!/usr/bin/env python3

import argparse
import os
import platform
import shutil
import subprocess
import sys

from pathlib import Path
from typing import Sequence

CWD = Path(__file__).resolve().parent
SYSTEM = platform.system()

BUILD_DIR = CWD / "build"
RESOURCES_DIR = CWD / "resources"
BINARY_NAME = "dash"

def run(cmd: Sequence[str], env: dict[str, str] | None = None, check: bool = True) -> int:
    print(f"exec: {subprocess.list2cmdline(list(cmd))}")

    result = subprocess.run(cmd, cwd=CWD, env=env)

    if check and result.returncode != 0:
        print(f"command failed with exit code {result.returncode}")
        sys.exit(result.returncode)

    return result.returncode

def tool_exists(tool: str) -> bool:
    return shutil.which(tool) is not None

def require_tool(tool: str) -> None:
    if tool_exists(tool):
        return

    print(f"{tool} not found in PATH")
    sys.exit(1)

def get_cpu_count() -> int:
    return os.cpu_count() or 4

def get_cmake_build_type(build_type: str) -> str:
    if build_type == "debug":
        return "Debug"

    return "Release"

def read_cached_build_type() -> str | None:
    cache_path = BUILD_DIR / "CMakeCache.txt"

    if not cache_path.exists():
        return None

    for line in cache_path.read_text(errors="replace").splitlines():
        if line.startswith("CMAKE_BUILD_TYPE:STRING="):
            return line.split("=", 1)[1].strip().lower()

    return None

def is_build_configured() -> bool:
    return (BUILD_DIR / "CMakeCache.txt").exists() and (BUILD_DIR / "build.ninja").exists()

def get_source_files() -> list[str]:
    patterns = ("*.c", "*.cc", "*.cpp", "*.cxx", "*.h", "*.hh", "*.hpp", "*.hxx")
    files: list[Path] = []

    for pattern in patterns:
        files.extend((CWD / "src").rglob(pattern))

    return [str(path) for path in sorted(files)]

def configure(build_type: str) -> int:
    require_tool("cmake")
    require_tool("ninja")

    if BUILD_DIR.exists() and (BUILD_DIR / "CMakeCache.txt").exists() and not (BUILD_DIR / "build.ninja").exists():
        shutil.rmtree(BUILD_DIR)

    cmake_build_type = get_cmake_build_type(build_type)
    cmd = [
        "cmake",
        "-Wno-dev",
        "-G",
        "Ninja",
        "-B",
        str(BUILD_DIR),
        "-S",
        str(CWD),
        f"-DCMAKE_BUILD_TYPE={cmake_build_type}",
    ]

    if SYSTEM != "Windows" and tool_exists("clang") and tool_exists("clang++"):
        cmd.extend([
            "-DCMAKE_C_COMPILER=clang",
            "-DCMAKE_CXX_COMPILER=clang++",
        ])

    return run(cmd)

def build(build_type: str | None) -> int:
    selected_build_type = build_type or read_cached_build_type() or "debug"

    if not is_build_configured() or selected_build_type != read_cached_build_type():
        configure(selected_build_type)

    return run([
        "cmake",
        "--build",
        str(BUILD_DIR),
        "--parallel",
        str(get_cpu_count()),
    ])

def format_code() -> int:
    require_tool("clang-format")

    source_files = get_source_files()

    if len(source_files) == 0:
        print("no source files found")
        return 0

    return run(["clang-format", "-i", *source_files])

def clean() -> int:
    if not BUILD_DIR.exists():
        print("build directory doesn't exist")
        return 0

    shutil.rmtree(BUILD_DIR)
    return 0

def init() -> int:
    if (CWD / ".gitmodules").exists():
        run(["git", "submodule", "update", "--init", "--recursive"])

    require_tool("cmake")
    require_tool("ninja")
    require_tool("clang-format")

    return 0

def run_binary() -> int:
    candidates = [
        BUILD_DIR / BINARY_NAME,
        BUILD_DIR / f"{BINARY_NAME}.exe",
        BUILD_DIR / "Debug" / f"{BINARY_NAME}.exe",
        BUILD_DIR / "Release" / f"{BINARY_NAME}.exe",
    ]

    binary_path = next((path for path in candidates if path.exists()), None)

    if binary_path is None:
        print("binary not found")
        return 1

    shutil.copytree(RESOURCES_DIR, BUILD_DIR / "resources", dirs_exist_ok=True)

    return run([str(binary_path)], check=False)

def main() -> None:
    parser = argparse.ArgumentParser(description="project helper script")
    parser.add_argument("command", choices=["init", "configure", "build", "run", "format", "clean"])
    parser.add_argument("--type", choices=["debug", "release"], default=None, dest="build_type")
    parser.add_argument("--run", action="store_true")

    args = parser.parse_args()

    commands = {
        "init": init,
        "configure": lambda: configure(args.build_type or "debug"),
        "build": lambda: build(args.build_type),
        "run": run_binary,
        "format": format_code,
        "clean": clean,
    }

    exit_code = commands[args.command]()

    if args.command == "build" and exit_code == 0 and args.run:
        exit_code = run_binary()

    sys.exit(exit_code)

if __name__ == "__main__":
    main()
